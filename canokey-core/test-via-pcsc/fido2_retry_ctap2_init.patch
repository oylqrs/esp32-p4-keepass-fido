+    def _bind_client(self, dev):
         self.dev = dev
         self.client = Fido2Client(dev, self.origin)
+        if not hasattr(self.client, "ctap2"):
+            raise RuntimeError("Fido2Client fell back to CTAP1 during CTAP2 initialization")
         self.ctap2 = self.client.ctap2
         self.ctap1 = CTAP1(dev)
 
+    def find_device(self, nfcInterfaceOnly=False):
+        self.nfc_interface_only = nfcInterfaceOnly
+        attempts = 10 if nfcInterfaceOnly else 1
+        last_error = None
+
+        for attempt in range(attempts):
+            dev = None
+            try:
+                if not nfcInterfaceOnly:
+                    print("--- HID ---")
+                    print(list(CtapHidDevice.list_devices()))
+                    dev = next(CtapHidDevice.list_devices(), None)
+
+                else:
+                    from fido2.pcsc import CtapPcscDevice
+
+                    print("--- NFC ---")
+                    dev = next(MoreRobustPcscDevice.list_devices(), None)
+
+                    if dev:
+                        self.is_nfc = True
+                        # For ACR1252 readers, with drivers installed
